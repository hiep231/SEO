{
	"$schema": "https://turborepo.dev/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"]
		},
		"check-types": {
			"dependsOn": ["^check-types"],
			"outputs": []
		},
		"lint": {
			"outputs": []
		},
		"dev": {
			"persistent": true,
			"cache": false,
			"dependsOn": ["^build"]
		}
	}
}

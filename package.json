{
	"packageManager": "pnpm@11.0.8",
	"scripts": {
		"build": "set NODE_OPTIONS=--max-old-space-size=8192 && turbo run build",
		"dev": "turbo run dev",
		"lint": "turbo run lint",
		"format": "prettier --write \"**/*.{ts,tsx}\"",
		"check-types": "turbo run check-types"
	},
	"devDependencies": {
		"@repo/eslint-config": "workspace:*",
		"turbo": "^2.9.9"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"puppeteer"
		]
	}
}
